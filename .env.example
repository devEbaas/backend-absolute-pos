# Postgres (used by both the `postgres` and `api` services in docker-compose.yml)
POSTGRES_USER=absolute_pos
POSTGRES_PASSWORD=change-me
POSTGRES_DB=absolute_pos

# Full connection string for Prisma. When running docker-compose, this is
# built automatically from the POSTGRES_* vars above (see docker-compose.yml)
# — only set it here for local `npx prisma` commands run on the host,
# e.g. `postgresql://absolute_pos:change-me@localhost:5433/absolute_pos?schema=public`
# (5433, not 5432, if you map the postgres container to the host for local
# `npx prisma` commands — see docker-compose.yml)
DATABASE_URL=

# Single shared secret for the bootstrap/admin endpoints (creating
# businesses and devices). Known only to the VPS operator — generate with
# `openssl rand -hex 32`. Never exposed to devices or the dashboard.
MASTER_API_KEY=change-me

# Public domains Caddy terminates TLS for.
DOMAIN_API=backend-pos.bekadev.online
DOMAIN_WEB=pos-web.bekadev.online

PORT=3000
