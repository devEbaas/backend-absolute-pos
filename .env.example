# Cadena de conexión de Postgres para Prisma.
# e.g. postgresql://absolute_pos:change-me@localhost:5432/absolute_pos?schema=public
DATABASE_URL=

# Secreto compartido único para los endpoints de bootstrap/admin (crear
# negocios, dispositivos y códigos de emparejamiento). Solo lo conoce quien
# opera el backend — generar con `openssl rand -hex 32`. Nunca se expone a
# los dispositivos ni al dashboard.
MASTER_API_KEY=change-me

# Firma los JWT emitidos por POST /auth/login (sesiones mobile) Y por
# POST /platform-admin/login (pos-root-dashboard) — dos espacios de token
# disjuntos que comparten este secreto, separados por el claim "scope" (ver
# PlatformAdminGuard). Generar con `openssl rand -hex 32`. Rotarlo invalida
# toda sesión mobile Y de dashboard activa de inmediato.
JWT_SECRET=change-me

# Orígenes permitidos por CORS, separados por coma — uno por dashboard que
# llame esta API desde el navegador (pos-root-dashboard, plataforma; y
# pos-business-dashboard, el del dueño del negocio). Vacío/ausente = CORS
# deshabilitado (nada puede llamar la API desde un navegador).
DASHBOARD_ORIGINS=https://admin-pos.bekadev.online,https://pos-client.absolutesystems.dev

# Mismo mecanismo que DASHBOARD_ORIGINS, pero para el sitio público de
# marketing (absolute-systems-web) — llama POST /demo-requests sin auth
# desde el navegador. Vacío/ausente = ese endpoint queda inalcanzable desde
# un navegador (CORS lo bloquea), aunque siga respondiendo a curl/Postman.
MARKETING_ORIGINS=https://absolutesystems.dev,https://www.absolutesystems.dev

PORT=3000
